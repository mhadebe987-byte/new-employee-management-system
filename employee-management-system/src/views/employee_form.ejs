<!doctype html><html><head><%- include('partials_head') %><title>EMS • <%= employee ? 'Edit' : 'New' %></title></head>
<body>
<nav class="nav"><div class="brand">EMS</div><div class="links">
<a href="/employees">Back</a><form method="post" action="/logout"><button class="linkbtn">Logout</button></form>
</div></nav>
<main class="container">
<h2><%= employee ? 'Edit Employee' : 'Add Employee' %></h2>
<% if (error) { %><div class="alert"><%= error %></div><% } %>
<div class="card">
<form method="post" action="<%= employee ? `/employees/${employee.id}/edit` : '/employees/new' %>">
  <div class="grid2">
    <div><label>Full name</label><input name="full_name" required value="<%= employee?.full_name || '' %>"/></div>
    <div><label>Email</label><input name="email" type="email" required value="<%= employee?.email || '' %>"/></div>
    <div><label>Phone</label><input name="phone" required value="<%= employee?.phone || '' %>"/></div>
    <div><label>Department</label><input name="department" required value="<%= employee?.department || '' %>"/></div>
    <div><label>Role</label><input name="role" required value="<%= employee?.role || '' %>"/></div>
    <div><label>Salary</label><input name="salary" type="number" min="0" value="<%= employee?.salary || 0 %>"/></div>
    <div><label>Hired date</label><input name="hired_date" type="date" required value="<%= employee?.hired_date || '' %>"/></div>
  </div>
  <button class="btn">Save</button>
</form></div></main></body></html>
